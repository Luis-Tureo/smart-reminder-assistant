    <string name="calendar_sync_google_auth_cancelled_inline">C&#243;digo: GOOGLE_AUTH_CANCELLED. Cancelaste la autorizaci&#243;n de Google Calendar. Puedes conectar la cuenta cuando quieras.</string>
