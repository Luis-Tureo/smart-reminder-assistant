    <string name="calendar_sync_microsoft_auth_cancelled_inline">C&#243;digo: MICROSOFT_AUTH_CANCELLED. Cancelaste la autorizaci&#243;n de Microsoft. Puedes conectar la cuenta cuando quieras.</string>
    <string name="calendar_sync_microsoft_auth_network_inline">C&#243;digo: MICROSOFT_AUTH_NETWORK_IO. Microsoft no pudo autorizar la cuenta por un problema de red. Revisa internet.</string>
