    <string name="calendar_sync_google_internal_error_inline">C&#243;digo: GOOGLE_AUTH_INTERNAL_ERROR. Google Play Services devolvi&#243; un error interno al autorizar Calendar. Actualiza Google Play Services e intenta nuevamente.</string>
