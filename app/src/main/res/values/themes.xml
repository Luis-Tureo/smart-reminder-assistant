<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.VoiceReminderApp" parent="Theme.Material3.Light.NoActionBar">

        <!-- Colores principales -->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/accent_purple</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Fondo -->
        <item name="android:colorBackground">@color/screen_background</item>
        <item name="colorSurface">@color/card_background</item>

        <!-- Textos -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/screen_background</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

        <!-- Botones -->
        <item name="materialButtonStyle">@style/Widget.Voice.Button</item>

    </style>

    <style name="Widget.Voice.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="ThemeOverlay.VoiceReminderApp.ReminderOptionsDialog"
        parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.VoiceReminderApp.ReminderOptionsDialog</item>
    </style>

    <style name="ShapeAppearanceOverlay.VoiceReminderApp.ReminderOptionsDialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/reminder_options_panel_corner_radius</item>
    </style>

</resources>
