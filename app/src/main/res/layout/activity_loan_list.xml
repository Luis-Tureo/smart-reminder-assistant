<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C4CBD6"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:background="@drawable/bg_assistant_header_panel">

            <ImageButton
                android:id="@+id/btnBackLoanList"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/manual_reminder_back"
                android:padding="8dp"
                android:src="@drawable/ic_calendar_back"
                app:tint="#F6F1E8" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:paddingHorizontal="58dp"
                android:text="@string/loan_module_title"
                android:textColor="#F6F1E8"
                android:textSize="22sp"
                android:textStyle="bold" />
        </FrameLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:columnCount="2"
            android:useDefaultMargins="false">

            <LinearLayout
                style="@style/LoanSummaryCell"
                android:layout_columnWeight="1">

                <TextView
                    style="@style/LoanSummaryLabel"
                    android:text="@string/loan_summary_lent_to_me" />

                <TextView
                    android:id="@+id/tvSummaryLentToMe"
                    style="@style/LoanSummaryValue" />
            </LinearLayout>

            <LinearLayout
                style="@style/LoanSummaryCell"
                android:layout_columnWeight="1"
                android:layout_marginStart="10dp">

                <TextView
                    style="@style/LoanSummaryLabel"
                    android:text="@string/loan_summary_i_owe" />

                <TextView
                    android:id="@+id/tvSummaryIOwe"
                    style="@style/LoanSummaryValue" />
            </LinearLayout>

            <LinearLayout
                style="@style/LoanSummaryCell"
                android:layout_columnWeight="1"
                android:layout_marginTop="10dp">

                <TextView
                    style="@style/LoanSummaryLabel"
                    android:text="@string/loan_summary_recovered" />

                <TextView
                    android:id="@+id/tvSummaryRecovered"
                    style="@style/LoanSummaryValue" />
            </LinearLayout>

            <LinearLayout
                style="@style/LoanSummaryCell"
                android:layout_columnWeight="1"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp">

                <TextView
                    style="@style/LoanSummaryLabel"
                    android:text="@string/loan_summary_pending" />

                <TextView
                    android:id="@+id/tvSummaryPending"
                    style="@style/LoanSummaryValue" />
            </LinearLayout>

            <LinearLayout
                style="@style/LoanSummaryCell"
                android:layout_width="match_parent"
                android:layout_columnSpan="2"
                android:layout_marginTop="10dp">

                <TextView
                    style="@style/LoanSummaryLabel"
                    android:text="@string/loan_summary_overdue" />

                <TextView
                    android:id="@+id/tvSummaryOverdue"
                    style="@style/LoanSummaryValue" />
            </LinearLayout>
        </GridLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/reminder_card_background"
            app:cardCornerRadius="22dp"
            app:cardElevation="3dp"
            app:strokeColor="@color/reminder_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/loan_search_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputLoanSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLoanFilter"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:textAllCaps="false" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLoanSort"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:minWidth="0dp"
                        android:textAllCaps="false" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateLoan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="14dp"
            android:minHeight="52dp"
            android:text="@string/loan_create"
            android:textAllCaps="false"
            android:textStyle="bold"
            app:backgroundTint="@color/calendar_toolbar_background"
            app:cornerRadius="24dp" />

        <TextView
            android:id="@+id/tvLoanListEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="18dp"
            android:gravity="center"
            android:text="@string/loan_list_empty"
            android:textColor="@color/reminder_text_secondary"
            android:textSize="15sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerLoans"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:paddingHorizontal="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="18dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
