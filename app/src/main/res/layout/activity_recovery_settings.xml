<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/recovery_screen_background" android:orientation="vertical">
    <LinearLayout android:layout_width="match_parent" android:layout_height="72dp" android:background="@color/recovery_toolbar_background" android:gravity="center_vertical" android:paddingHorizontal="8dp">
        <ImageButton android:id="@+id/btnBackRecoverySettings" android:layout_width="48dp" android:layout_height="48dp" android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/recovery_back" android:padding="12dp" android:src="@drawable/ic_calendar_back" app:tint="@color/recovery_toolbar_text" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/recovery_settings_title" android:textColor="@color/recovery_toolbar_text" android:textSize="21sp" android:textStyle="bold" />
    </LinearLayout>
    <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/recovery_settings_privacy" android:textSize="17sp" android:textStyle="bold" />
            <RadioGroup android:id="@+id/groupRecoveryNotificationPrivacy" android:layout_width="match_parent" android:layout_height="wrap_content">
                <com.google.android.material.radiobutton.MaterialRadioButton android:id="@+id/radioRecoveryDiscreet" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/recovery_settings_discreet" />
                <com.google.android.material.radiobutton.MaterialRadioButton android:id="@+id/radioRecoveryFull" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/recovery_settings_full" />
            </RadioGroup>
            <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchRecoveryVoice" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/recovery_settings_voice" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/recovery_settings_voice_summary" android:textColor="@color/recovery_muted" android:textSize="12sp" />
            <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchRecoveryBubble" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/recovery_settings_bubble" />
            <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchRecoveryMilestones" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/recovery_settings_milestones" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <com.google.android.material.textfield.TextInputLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="@string/recovery_settings_custom_milestone">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputRecoveryCustomMilestone" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" android:maxLength="4" />
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnAddRecoveryMilestone" style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="56dp" android:layout_marginStart="8dp" android:text="@string/recovery_settings_add_milestone" />
            </LinearLayout>
            <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchRecoveryStatistics" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/recovery_settings_statistics" />
            <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchRecoveryPaused" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:minHeight="48dp" android:text="@string/recovery_settings_pause" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/recovery_settings_reminder_type" android:textStyle="bold" />
            <Spinner android:id="@+id/spinnerRecoveryReminderType" android:layout_width="match_parent" android:layout_height="48dp" android:contentDescription="@string/recovery_settings_reminder_type" />
            <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchRecoveryCheckInReminder" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/recovery_settings_reminder_enabled" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnRecoveryReminderTime" style="?attr/materialButtonOutlinedStyle" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/recovery_settings_reminder_time" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnRecoveryEditGoal" style="?attr/materialButtonOutlinedStyle" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:minHeight="48dp" android:text="@string/recovery_edit" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnRecoverySettingsContacts" style="?attr/materialButtonOutlinedStyle" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/recovery_dashboard_contacts" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnSaveRecoverySettings" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:minHeight="52dp" android:text="@string/recovery_save" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnDeleteRecoveryGoal" style="?attr/materialButtonOutlinedStyle" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:minHeight="48dp" android:text="@string/recovery_settings_delete_goal" android:textColor="@color/recovery_danger" app:strokeColor="@color/recovery_danger" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:background="@color/recovery_warning_background" android:padding="12dp" android:text="@string/recovery_disclaimer" android:textColor="@color/recovery_warning_text" android:textSize="13sp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
