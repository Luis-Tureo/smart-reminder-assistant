<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C4CBD6"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <FrameLayout
            android:id="@+id/headerBar"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:background="@drawable/bg_assistant_header_panel">

            <ImageButton
                android:id="@+id/btnBackManualReminder"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/manual_reminder_back"
                android:padding="8dp"
                android:src="@drawable/ic_calendar_back"
                app:tint="#F6F1E8" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvManualReminderScreenTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="2"
                    android:paddingStart="58dp"
                    android:paddingEnd="58dp"
                    android:text="@string/manual_reminder_screen_title"
                    android:textColor="#F6F1E8"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvManualReminderScreenSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="monospace"
                    android:includeFontPadding="false"
                    android:text="@string/manual_reminder_screen_subtitle"
                    android:textColor="#E7E2DA"
                    android:textSize="10sp"
                    android:visibility="gone" />
                </LinearLayout>
        </FrameLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCameraInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/reminder_card_background"
            app:cardCornerRadius="28dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/reminder_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/tvCameraInputTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/camera_reminder_input_title"
                    android:textColor="@color/reminder_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCameraInputSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/camera_reminder_input_subtitle"
                    android:textColor="@color/reminder_text_secondary"
                    android:textSize="13sp" />

                <ImageView
                    android:id="@+id/imageCameraPreview"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="14dp"
                    android:adjustViewBounds="true"
                    android:background="@drawable/bg_assistant_scene_content"
                    android:contentDescription="@string/camera_reminder_preview_content_description"
                    android:padding="8dp"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_menu_report_image"
                    android:visibility="gone" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressCameraScan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:indeterminate="true"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvCameraScanStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/camera_reminder_scan_idle"
                    android:textColor="@color/reminder_text_secondary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTakeCameraReminderPhoto"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:maxLines="2"
                        android:minHeight="48dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="10dp"
                        android:text="@string/camera_reminder_take_photo"
                        android:textAllCaps="false" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectCameraReminderImage"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:maxLines="2"
                        android:minHeight="48dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="10dp"
                        android:text="@string/camera_reminder_select_image"
                        android:textAllCaps="false" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/reminder_card_background"
            app:cardCornerRadius="28dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/reminder_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/manual_reminder_section_details"
                    android:textColor="@color/reminder_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/manual_reminder_details_help"
                    android:textColor="@color/reminder_text_secondary"
                    android:textSize="13sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="@string/manual_reminder_title_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputReminderTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapSentences"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/reminder_detail_label">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputReminderDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top|start"
                        android:inputType="textCapSentences|textMultiLine"
                        android:minLines="3"
                        android:maxLines="6" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/reminder_card_background"
            app:cardCornerRadius="28dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/reminder_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/manual_reminder_section_schedule"
                    android:textColor="@color/reminder_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:baselineAligned="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectDate"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:maxLines="2"
                        android:minHeight="54dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="10dp"
                        android:text="@string/reminder_select_date" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectTime"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:maxLines="2"
                        android:minHeight="54dp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="10dp"
                        android:text="@string/reminder_select_time" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchUrgent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/reminder_urgent_label" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/reminder_card_background"
            app:cardCornerRadius="28dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/reminder_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/manual_reminder_section_recurrence"
                    android:textColor="@color/reminder_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/manual_reminder_recurrence_help"
                    android:textColor="@color/reminder_text_secondary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:id="@+id/gridRecurrenceOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRecurrenceNone"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.7"
                            android:maxLines="1"
                            android:minHeight="44dp"
                            android:minWidth="0dp"
                            android:paddingHorizontal="8dp"
                            android:singleLine="true"
                            android:text="@string/reminder_recurrence_none"
                            android:textAllCaps="false"
                            android:textColor="@color/reminder_text_primary"
                            android:textSize="14sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRecurrenceDaily"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:maxLines="1"
                            android:minHeight="44dp"
                            android:minWidth="0dp"
                            android:paddingHorizontal="8dp"
                            android:singleLine="true"
                            android:text="@string/reminder_recurrence_daily"
                            android:textAllCaps="false"
                            android:textColor="@color/reminder_text_primary"
                            android:textSize="14sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRecurrenceWeekly"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1.1"
                            android:maxLines="1"
                            android:minHeight="44dp"
                            android:minWidth="0dp"
                            android:paddingHorizontal="8dp"
                            android:singleLine="true"
                            android:text="@string/reminder_recurrence_weekly"
                            android:textAllCaps="false"
                            android:textColor="@color/reminder_text_primary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRecurrenceMonthly"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:maxLines="1"
                            android:minHeight="44dp"
                            android:minWidth="0dp"
                            android:paddingHorizontal="8dp"
                            android:singleLine="true"
                            android:text="@string/reminder_recurrence_monthly"
                            android:textAllCaps="false"
                            android:textColor="@color/reminder_text_primary"
                            android:textSize="14sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRecurrenceYearly"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:maxLines="1"
                            android:minHeight="44dp"
                            android:minWidth="0dp"
                            android:paddingHorizontal="8dp"
                            android:singleLine="true"
                            android:text="@string/reminder_recurrence_yearly"
                            android:textAllCaps="false"
                            android:textColor="@color/reminder_text_primary"
                            android:textSize="14sp" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1.2" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/containerManualCalendarSyncOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/reminder_card_background"
            app:cardCornerRadius="28dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/reminder_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/calendar_sync_targets_title"
                    android:textColor="@color/reminder_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/checkManualSyncGoogle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/calendar_sync_target_google"
                    android:visibility="gone" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/checkManualSyncMicrosoft"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/calendar_sync_target_microsoft"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveReminder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:maxLines="1"
            android:minHeight="52dp"
            android:minWidth="0dp"
            android:paddingVertical="14dp"
            android:text="@string/manual_reminder_save_button"
            android:textAllCaps="false"
            android:textStyle="bold"
            app:backgroundTint="@color/calendar_toolbar_background"
            app:cornerRadius="24dp"
            app:rippleColor="@color/ripple_soft" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
