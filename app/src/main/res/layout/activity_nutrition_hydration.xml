<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/nutrition_screen_background">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingBottom="24dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="72dp" android:orientation="horizontal"
            android:gravity="center_vertical" android:background="@color/nutrition_toolbar_background" android:paddingHorizontal="8dp">
            <ImageButton android:id="@+id/btnBackNutritionHydration" android:layout_width="48dp" android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/nutrition_back"
                android:src="@drawable/ic_calendar_back" android:padding="12dp" app:tint="@color/nutrition_toolbar_text" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/nutrition_hydration_title" android:textColor="@color/nutrition_toolbar_text" android:textSize="22sp" android:textStyle="bold" />
        </LinearLayout>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp"
            android:text="@string/nutrition_hydration_neutral" android:textColor="@color/reminder_text_secondary" />
        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/checkNutritionHydrationEnabled"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp"
            android:text="@string/nutrition_hydration_enabled" />
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputNutritionHydrationTarget"
            android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginHorizontal="16dp"
            android:hint="@string/nutrition_hydration_target" android:inputType="number" />
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputNutritionHydrationContainer"
            android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginHorizontal="16dp"
            android:hint="@string/nutrition_hydration_container" android:inputType="number" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingHorizontal="12dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionHydrationStart" style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp"
                android:text="@string/nutrition_hydration_start" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionHydrationEnd" style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp"
                android:text="@string/nutrition_hydration_end" />
        </LinearLayout>
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputNutritionHydrationInterval"
            android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginHorizontal="16dp"
            android:hint="@string/nutrition_hydration_interval" android:inputType="number" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnSaveNutritionHydrationSettings"
            android:layout_width="match_parent" android:layout_height="52dp" android:layout_margin="16dp"
            android:text="@string/nutrition_hydration_save_settings" />
        <TextView android:id="@+id/tvNutritionHydrationTotal" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp" android:textColor="@color/reminder_text_primary" android:textSize="17sp" android:textStyle="bold" />
        <ProgressBar android:id="@+id/progressNutritionHydrationDetail" style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="12dp" android:layout_margin="16dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingHorizontal="12dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionHydrationAddContainer"
                style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:layout_margin="4dp" android:text="@string/nutrition_hydration_add_container" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionHydrationAdd250"
                style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:layout_margin="4dp" android:text="@string/nutrition_hydration_add_250" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionHydrationAdd500"
                style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:layout_margin="4dp" android:text="@string/nutrition_hydration_add_500" />
        </LinearLayout>
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputNutritionHydrationCustom"
            android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginHorizontal="16dp"
            android:hint="@string/nutrition_hydration_custom" android:inputType="number" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionHydrationAddCustom"
            style="?attr/materialButtonOutlinedStyle" android:layout_width="match_parent" android:layout_height="48dp"
            android:layout_marginHorizontal="16dp" android:text="@string/nutrition_hydration_add_custom" />
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerNutritionHydration" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:nestedScrollingEnabled="false" android:padding="12dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

