<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="5dp"
    app:cardBackgroundColor="@color/routine_card_background"
    app:cardCornerRadius="@dimen/routine_card_radius"
    app:cardElevation="1dp"
    app:strokeColor="@color/routine_card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvRoutineTemplateName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/reminder_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRoutineTemplateDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/reminder_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/routine_template_benefits"
            android:textColor="@color/reminder_text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRoutineTemplateBenefits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/reminder_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvRoutineTemplateMetadata"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:textColor="@color/reminder_text_secondary" android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewRoutineTemplate" style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="10dp"
            android:text="@string/routine_template_view" android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUseRoutineTemplate"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="12dp"
            android:minHeight="48dp"
            android:text="@string/routine_template_use"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteRoutineTemplate" style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="@string/routine_template_delete" android:textAllCaps="false" android:visibility="gone" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
