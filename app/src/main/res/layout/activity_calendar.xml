<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/calendar_screen_background"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/containerUnifiedHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/calendar_toolbar_background"
        android:minHeight="88dp"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="14dp">

        <TextView
            android:id="@+id/tvUnifiedScreenTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/unified_screen_title"
            android:textColor="@color/calendar_toolbar_text"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvUnifiedScreenSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:maxLines="2"
            android:text="@string/unified_screen_subtitle"
            android:textColor="@color/calendar_toolbar_text"
            android:textSize="14sp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingHorizontal="14dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/containerCalendarContent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_max="@dimen/unified_content_max_width">

            <include
                layout="@layout/view_calendar_filters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:id="@+id/containerCalendarPlannerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/calendar_card_background"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/calendar_card_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:id="@+id/containerCalendarControls"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <ImageButton
                            android:id="@+id/btnPreviousMonth"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_calendar_navigation_button"
                            android:contentDescription="@string/calendar_previous_month"
                            android:padding="12dp"
                            android:src="@drawable/ic_calendar_chevron_left"
                            app:tint="@color/calendar_navigation_icon" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="8dp"
                            android:layout_weight="1"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnMonthSelector"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="0dp"
                                android:layout_height="@dimen/calendar_selector_height"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:includeFontPadding="false"
                                android:maxLines="1"
                                android:minWidth="0dp"
                                android:paddingHorizontal="8dp"
                                android:singleLine="true"
                                android:textAllCaps="false"
                                android:textColor="@color/calendar_title_text"
                                android:textSize="14sp"
                                app:cornerRadius="14dp"
                                app:strokeColor="@color/calendar_selector_stroke" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnYearSelector"
                                style="?attr/materialButtonOutlinedStyle"
                                android:layout_width="@dimen/calendar_year_selector_width"
                                android:layout_height="@dimen/calendar_selector_height"
                                android:layout_marginStart="6dp"
                                android:gravity="center"
                                android:includeFontPadding="false"
                                android:maxLines="1"
                                android:minWidth="0dp"
                                android:paddingHorizontal="4dp"
                                android:singleLine="true"
                                android:textAllCaps="false"
                                android:textColor="@color/calendar_title_text"
                                android:textSize="14sp"
                                app:cornerRadius="14dp"
                                app:strokeColor="@color/calendar_selector_stroke" />
                        </LinearLayout>

                        <ImageButton
                            android:id="@+id/btnNextMonth"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_calendar_navigation_button"
                            android:contentDescription="@string/calendar_next_month"
                            android:padding="12dp"
                            android:src="@drawable/ic_calendar_chevron_right"
                            app:tint="@color/calendar_navigation_icon" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCalendarGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/calendar_card_background"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/calendar_card_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="10dp"
                        android:paddingTop="18dp"
                        android:paddingBottom="18dp">

                        <LinearLayout
                            android:id="@+id/containerCalendarWeekdays"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:importantForAccessibility="no"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/calendar_weekday_monday"
                                android:textColor="@color/calendar_caption_text"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/calendar_weekday_tuesday"
                                android:textColor="@color/calendar_caption_text"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/calendar_weekday_wednesday"
                                android:textColor="@color/calendar_caption_text"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/calendar_weekday_thursday"
                                android:textColor="@color/calendar_caption_text"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/calendar_weekday_friday"
                                android:textColor="@color/calendar_caption_text"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/calendar_weekday_saturday"
                                android:textColor="@color/calendar_caption_text"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/tvCalendarWeekdaySunday"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/calendar_weekday_sunday"
                                android:textColor="@color/calendar_sunday_text"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <GridLayout
                            android:id="@+id/gridCalendarDays"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/calendar_weekdays_to_grid_spacing"
                            android:alignmentMode="alignMargins"
                            android:columnCount="7"
                            android:useDefaultMargins="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCalendarSelectedDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/calendar_detail_background"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/calendar_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/tvSelectedDateTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/calendar_title_text"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSelectedDateSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/calendar_body_text"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvHolidaySummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_calendar_indicator_holiday"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="8dp"
                        android:textColor="@color/calendar_indicator_holiday_text"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvCalendarEmptyState"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="@color/calendar_body_text"
                        android:textSize="15sp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/containerDayDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical" />

                    <LinearLayout
                        android:id="@+id/containerSelectedDateActions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="vertical">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCalendarCreateReminder"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxLines="1"
                            android:minHeight="48dp"
                            android:minWidth="0dp"
                            android:paddingHorizontal="18dp"
                            android:text="@string/calendar_create_reminder"
                            android:textAllCaps="false"
                            android:textColor="@color/calendar_title_text"
                            android:textSize="15sp"
                            app:cornerRadius="24dp"
                            app:strokeColor="@color/calendar_title_text" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCalendarAssistant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/calendar_card_background"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/calendar_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/tvCalendarAssistantHeading"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/unified_assistant_heading"
                        android:textColor="@color/calendar_title_text"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/unified_assistant_supporting_text"
                        android:textColor="@color/calendar_body_text"
                        android:textSize="15sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCalendarAssistant"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:minHeight="48dp"
                        android:text="@string/assistant_speak_button"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        app:cornerRadius="24dp"
                        app:icon="@android:drawable/ic_btn_speak_now"
                        app:iconGravity="textStart"
                        app:iconPadding="10dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvCalendarConnectionsHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="4dp"
                android:text="@string/calendar_connections_heading"
                android:textColor="@color/calendar_title_text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCalendarSyncStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@color/info_box_background"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/calendar_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvCalendarSyncStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/calendar_sync_status_none"
                        android:textColor="@color/calendar_body_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCalendarLastSync"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/calendar_caption_text"
                        android:textSize="11sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvCalendarSyncInlineNotice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/calendar_sync_delete_finished_inline"
                        android:textColor="@color/calendar_body_text"
                        android:textSize="12sp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/containerCalendarSyncError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_calendar_sync_error"
                        android:orientation="vertical"
                        android:padding="10dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvCalendarSyncError"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxLines="5"
                            android:textColor="@color/reminder_delete_red"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCalendarGoogleSync"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:minHeight="48dp"
                        android:text="@string/calendar_sync_google_connect"
                        android:textAllCaps="false"
                        android:textColor="@color/calendar_title_text"
                        app:cornerRadius="22dp"
                        app:strokeColor="@color/calendar_title_text" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCalendarMicrosoftSync"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:minHeight="48dp"
                        android:text="@string/calendar_sync_microsoft_connect"
                        android:textAllCaps="false"
                        android:textColor="@color/calendar_title_text"
                        app:cornerRadius="22dp"
                        app:strokeColor="@color/calendar_title_text" />

                    <LinearLayout
                        android:id="@+id/containerCalendarDisconnectActions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCalendarGoogleDisconnect"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="48dp"
                            android:text="@string/calendar_sync_google_disconnect"
                            android:textAllCaps="false"
                            android:textColor="@color/reminder_delete_red"
                            android:visibility="gone"
                            app:cornerRadius="22dp"
                            app:strokeColor="@color/reminder_delete_red" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCalendarMicrosoftDisconnect"
                            style="?attr/materialButtonOutlinedStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:minHeight="48dp"
                            android:text="@string/calendar_sync_microsoft_disconnect"
                            android:textAllCaps="false"
                            android:textColor="@color/reminder_delete_red"
                            android:visibility="gone"
                            app:cornerRadius="22dp"
                            app:strokeColor="@color/reminder_delete_red" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
