<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/calendar_screen_background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarCalendar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/calendar_toolbar_background"
        android:elevation="0dp"
        android:minHeight="?attr/actionBarSize"
        android:paddingHorizontal="8dp"
        app:navigationIcon="@drawable/ic_calendar_back"
        app:navigationIconTint="@color/calendar_toolbar_icon"
        app:title="@string/calendar_screen_title"
        app:titleCentered="false"
        app:titleTextColor="@color/calendar_toolbar_text" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingHorizontal="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/containerCalendarPlannerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/calendar_card_background"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/calendar_card_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/calendar_planner_overline"
                            android:textAllCaps="true"
                            android:textColor="@color/calendar_caption_text"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCalendarMonthTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/calendar_title_text"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/containerCalendarControls"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:paddingStart="@dimen/calendar_controls_row_side_spacing"
                            android:paddingEnd="@dimen/calendar_controls_row_side_spacing">

                            <ImageButton
                                android:id="@+id/btnPreviousMonth"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_calendar_navigation_button"
                                android:contentDescription="@string/calendar_previous_month"
                                android:padding="8dp"
                                android:src="@drawable/ic_calendar_chevron_left"
                                android:tint="@color/calendar_navigation_icon"
                                app:layout_constraintBottom_toBottomOf="@id/inputMonthSelector"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="@id/inputMonthSelector" />

                            <ImageButton
                                android:id="@+id/btnNextMonth"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_calendar_navigation_button"
                                android:contentDescription="@string/calendar_next_month"
                                android:padding="8dp"
                                android:src="@drawable/ic_calendar_chevron_right"
                                android:tint="@color/calendar_navigation_icon"
                                app:layout_constraintBottom_toBottomOf="@id/inputMonthSelector"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="@id/inputMonthSelector" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/layoutMonthSelector"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/calendar_controls_button_to_selector_spacing"
                                android:layout_marginEnd="@dimen/calendar_controls_selector_spacing"
                                app:boxBackgroundColor="@color/calendar_selector_background"
                                app:boxCornerRadiusBottomEnd="14dp"
                                app:boxCornerRadiusBottomStart="14dp"
                                app:boxCornerRadiusTopEnd="14dp"
                                app:boxCornerRadiusTopStart="14dp"
                                app:boxStrokeColor="@color/calendar_selector_stroke"
                                app:endIconTint="@color/calendar_selector_icon"
                                app:hintEnabled="false"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toStartOf="@id/layoutYearSelector"
                                app:layout_constraintHorizontal_weight="1.2"
                                app:layout_constraintStart_toEndOf="@id/btnPreviousMonth"
                                app:layout_constraintTop_toTopOf="parent">

                                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                    android:id="@+id/inputMonthSelector"
                                    android:layout_width="match_parent"
                                    android:layout_height="@dimen/calendar_selector_height"
                                    android:ellipsize="end"
                                    android:gravity="center_vertical"
                                    android:inputType="none"
                                    android:maxLines="1"
                                    android:minHeight="0dp"
                                    android:paddingTop="0dp"
                                    android:paddingBottom="0dp"
                                    android:singleLine="true"
                                    android:textColor="@color/calendar_title_text"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/layoutYearSelector"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/calendar_controls_selector_spacing"
                                android:layout_marginEnd="@dimen/calendar_controls_button_to_selector_spacing"
                                android:minWidth="@dimen/calendar_year_selector_min_width"
                                app:boxBackgroundColor="@color/calendar_selector_background"
                                app:boxCornerRadiusBottomEnd="14dp"
                                app:boxCornerRadiusBottomStart="14dp"
                                app:boxCornerRadiusTopEnd="14dp"
                                app:boxCornerRadiusTopStart="14dp"
                                app:boxStrokeColor="@color/calendar_selector_stroke"
                                app:endIconTint="@color/calendar_selector_icon"
                                app:hintEnabled="false"
                                app:layout_constraintBottom_toBottomOf="@id/layoutMonthSelector"
                                app:layout_constraintEnd_toStartOf="@id/btnNextMonth"
                                app:layout_constraintStart_toEndOf="@id/layoutMonthSelector"
                                app:layout_constraintTop_toTopOf="@id/layoutMonthSelector">

                                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                    android:id="@+id/inputYearSelector"
                                    android:layout_width="match_parent"
                                    android:layout_height="@dimen/calendar_selector_height"
                                    android:ellipsize="end"
                                    android:gravity="center_vertical"
                                    android:inputType="none"
                                    android:maxLines="1"
                                    android:minEms="5"
                                    android:minHeight="0dp"
                                    android:paddingTop="0dp"
                                    android:paddingBottom="0dp"
                                    android:singleLine="true"
                                    android:textColor="@color/calendar_title_text"
                                    android:textSize="14sp" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/calendar_controls_to_grid_section_spacing"
                    app:cardBackgroundColor="@color/calendar_card_background"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/calendar_card_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="14dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <LinearLayout
                            android:id="@+id/containerCalendarWeekdays"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/calendar_weekday_monday"
                                android:textColor="@color/calendar_caption_text"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/calendar_weekday_tuesday"
                                android:textColor="@color/calendar_caption_text"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/calendar_weekday_wednesday"
                                android:textColor="@color/calendar_caption_text"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/calendar_weekday_thursday"
                                android:textColor="@color/calendar_caption_text"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/calendar_weekday_friday"
                                android:textColor="@color/calendar_caption_text"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/calendar_weekday_saturday"
                                android:textColor="@color/calendar_caption_text"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="@string/calendar_weekday_sunday"
                                android:textColor="@color/calendar_caption_text"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <GridLayout
                            android:id="@+id/gridCalendarDays"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/calendar_weekdays_to_grid_spacing"
                            android:alignmentMode="alignMargins"
                            android:columnCount="7"
                            android:useDefaultMargins="false" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@color/calendar_legend_background"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/calendar_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/calendar_legend_title"
                        android:textColor="@color/calendar_title_text"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            style="@style/TextAppearance.Material3.LabelLarge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_calendar_indicator_reminder"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:text="@string/calendar_legend_reminder"
                            android:textColor="@color/calendar_indicator_reminder_text" />

                        <Space
                            android:layout_width="8dp"
                            android:layout_height="1dp" />

                        <TextView
                            style="@style/TextAppearance.Material3.LabelLarge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_calendar_indicator_birthday"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:text="@string/calendar_legend_birthday"
                            android:textColor="@color/calendar_indicator_birthday_text" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal">

                        <TextView
                            style="@style/TextAppearance.Material3.LabelLarge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_calendar_indicator_holiday"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:text="@string/calendar_legend_holiday"
                            android:textColor="@color/calendar_indicator_holiday_text" />

                        <Space
                            android:layout_width="8dp"
                            android:layout_height="1dp" />

                        <TextView
                            style="@style/TextAppearance.Material3.LabelLarge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_calendar_indicator_completed"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:text="@string/calendar_legend_completed"
                            android:textColor="@color/calendar_indicator_completed_text" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="6dp"
                app:cardBackgroundColor="@color/calendar_detail_background"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/calendar_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvSelectedDateTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/calendar_title_text"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSelectedDateSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/calendar_body_text"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvHolidaySummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_calendar_indicator_holiday"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="8dp"
                        android:textColor="@color/calendar_indicator_holiday_text"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvCalendarEmptyState"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="@color/calendar_body_text"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/containerDayDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="vertical" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
