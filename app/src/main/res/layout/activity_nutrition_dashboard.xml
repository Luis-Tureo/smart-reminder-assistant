<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/nutrition_screen_background" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingBottom="24dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="72dp"
            android:background="@color/nutrition_toolbar_background" android:gravity="center_vertical"
            android:orientation="horizontal" android:paddingHorizontal="8dp">
            <ImageButton android:id="@+id/btnBackNutritionDashboard" android:layout_width="48dp"
                android:layout_height="48dp" android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/nutrition_back" android:padding="12dp"
                android:src="@drawable/ic_calendar_back" app:tint="@color/nutrition_toolbar_text" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/nutrition_module_title" android:textColor="@color/nutrition_toolbar_text"
                android:textSize="22sp" android:textStyle="bold" />
        </LinearLayout>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:padding="16dp" android:text="@string/nutrition_dashboard_subtitle"
            android:textColor="@color/reminder_text_secondary" android:textSize="15sp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp" android:background="@color/nutrition_warning_background"
            android:padding="14dp" android:text="@string/nutrition_disclaimer"
            android:textColor="@color/nutrition_warning_text" android:textSize="14sp" />
        <com.luistureo.voicereminderapp.presentation.assistant.AssistantDialogueBubbleView
            android:id="@+id/nutritionAssistantBubble"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            android:contentDescription="@string/assistant_dialogue_content_description" />
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_margin="16dp"
            app:cardBackgroundColor="@color/nutrition_card_background" app:cardCornerRadius="20dp"
            app:strokeColor="@color/nutrition_card_stroke" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:id="@+id/tvNutritionDashboardSummary" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textColor="@color/reminder_text_primary"
                    android:textSize="17sp" android:textStyle="bold" />
                <TextView android:id="@+id/tvNutritionPendingReminders" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginTop="8dp"
                    android:textColor="@color/reminder_text_secondary" android:textSize="14sp" />
                <TextView android:id="@+id/tvNutritionHydrationSummary" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:layout_marginTop="8dp"
                    android:textColor="@color/reminder_text_secondary" android:textSize="14sp" />
                <ProgressBar android:id="@+id/progressNutritionHydration" style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent" android:layout_height="12dp" android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <TextView android:id="@+id/tvNutritionDashboardEmpty" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:gravity="center" android:padding="20dp"
            android:text="@string/nutrition_dashboard_empty" android:textColor="@color/reminder_text_secondary" />
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerNutritionTodayMeals"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" android:paddingHorizontal="12dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionQuickAdd"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp" android:text="@string/nutrition_quick_add" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="12dp" android:paddingTop="12dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionPlanning"
                style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_height="52dp"
                android:layout_weight="1" android:layout_margin="4dp" android:text="@string/nutrition_planning_title" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionHydration"
                style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_height="52dp"
                android:layout_weight="1" android:layout_margin="4dp" android:text="@string/nutrition_hydration_title" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="12dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionShopping"
                style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_height="52dp"
                android:layout_weight="1" android:layout_margin="4dp" android:text="@string/nutrition_shopping_title" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionTemplates"
                style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_height="52dp"
                android:layout_weight="1" android:layout_margin="4dp" android:text="@string/nutrition_templates_title" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="12dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionPreferences"
                style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_height="52dp"
                android:layout_weight="1" android:layout_margin="4dp" android:text="@string/nutrition_preferences_title" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionStatistics"
                style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_height="52dp"
                android:layout_weight="1" android:layout_margin="4dp" android:text="@string/nutrition_statistics_title" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
