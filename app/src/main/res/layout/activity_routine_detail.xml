<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/routine_toolbar_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btnBackRoutineDetail"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/routine_back"
            android:padding="12dp"
            android:src="@drawable/ic_calendar_back"
            app:tint="@color/routine_toolbar_text" />

        <ImageView
            android:id="@+id/imageRoutineDetailPeriod"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="@null"
            android:padding="6dp" />

        <TextView
            android:id="@+id/tvRoutineDetailName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/routine_toolbar_text"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvRoutineDisabled"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@drawable/bg_routine_disabled"
        android:gravity="center"
        android:padding="12dp"
        android:text="@string/routine_disabled"
        android:textColor="@color/routine_disabled_text"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvRoutineDetailDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:textColor="@color/reminder_text_secondary"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tvRoutineDetailProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:textColor="@color/reminder_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressRoutineDetail"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:max="100"
        app:indicatorColor="@color/routine_primary"
        app:trackColor="@color/routine_primary_soft"
        app:trackCornerRadius="4dp" />

    <TextView
        android:id="@+id/tvRoutineSuccess"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_routine_success"
        android:gravity="center"
        android:padding="12dp"
        android:text="@string/routine_success"
        android:textColor="@color/routine_success_text"
        android:textStyle="bold"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvRoutineTasksEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp"
        android:text="@string/routine_no_tasks"
        android:textColor="@color/reminder_text_secondary"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerRoutineTasks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartRoutineAssistant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:text="@string/routine_start_with_assistant"
            android:textAllCaps="false"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCompleteRoutine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:text="@string/routine_complete"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMarkRoutinePartial"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:text="@string/routine_mark_partial"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditRoutine"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="48dp"
            android:text="@string/routine_edit"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDuplicateRoutine" style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="8dp"
            android:text="@string/routine_duplicate" android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveRoutineAsTemplate" style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="8dp"
            android:text="@string/routine_save_personal_template" android:textAllCaps="false" />
    </LinearLayout>
</LinearLayout>
