<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/routine_postpone_title"
        android:textColor="@color/reminder_text_primary"
        android:textSize="21sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/routine_postpone_subtitle"
        android:textColor="@color/reminder_text_secondary"
        android:textSize="14sp" />

    <RadioGroup
        android:id="@+id/groupRoutinePostpone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/radioRoutinePostpone5"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/routine_postpone_5" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/radioRoutinePostpone10"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/routine_postpone_10" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/radioRoutinePostpone30"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/routine_postpone_30" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/radioRoutinePostpone60"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/routine_postpone_60" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/radioRoutinePostponeCustom"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/routine_postpone_custom" />
    </RadioGroup>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutRoutinePostponeCustom"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/routine_postpone_custom_hint"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputRoutinePostponeCustom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelRoutinePostpone"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="5dp"
            android:layout_weight="1"
            android:minHeight="48dp"
            android:text="@string/routine_task_cancel"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmRoutinePostpone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_weight="1"
            android:minHeight="48dp"
            android:text="@string/routine_notification_postpone_action"
            android:textAllCaps="false" />
    </LinearLayout>
</LinearLayout>
