<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvCalendarFiltersHeading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="4dp"
        android:gravity="center"
        android:text="@string/calendar_filters_heading"
        android:textAlignment="center"
        android:textColor="@color/calendar_title_text"
        android:textSize="20sp"
        android:textStyle="bold" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        app:cardBackgroundColor="@color/calendar_legend_background"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/calendar_card_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/calendar_legend_title"
                android:textColor="@color/calendar_title_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCalendarFilterReminder"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    android:checkable="true"
                    app:rippleColor="@color/ripple_soft"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:minHeight="48dp"
                        android:orientation="horizontal"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp">

                        <View
                            android:id="@+id/dotCalendarFilterReminder"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/bg_calendar_dot"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:id="@+id/tvCalendarFilterReminder"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:maxLines="2"
                            android:text="@string/calendar_legend_reminder" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCalendarFilterBirthday"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    android:checkable="true"
                    app:rippleColor="@color/ripple_soft"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:minHeight="48dp"
                        android:orientation="horizontal"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp">

                        <View
                            android:id="@+id/dotCalendarFilterBirthday"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/bg_calendar_dot"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:id="@+id/tvCalendarFilterBirthday"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:maxLines="2"
                            android:text="@string/calendar_legend_birthday" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCalendarFilterHoliday"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    android:checkable="true"
                    app:rippleColor="@color/ripple_soft"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:minHeight="48dp"
                        android:orientation="horizontal"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp">

                        <View
                            android:id="@+id/dotCalendarFilterHoliday"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/bg_calendar_dot"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:id="@+id/tvCalendarFilterHoliday"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:maxLines="2"
                            android:text="@string/calendar_legend_holiday" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCalendarFilterCompleted"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    android:checkable="true"
                    app:rippleColor="@color/ripple_soft"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:minHeight="48dp"
                        android:orientation="horizontal"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp">

                        <View
                            android:id="@+id/dotCalendarFilterCompleted"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/bg_calendar_dot"
                            android:importantForAccessibility="no" />

                        <TextView
                            android:id="@+id/tvCalendarFilterCompleted"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:maxLines="2"
                            android:text="@string/calendar_legend_completed" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCalendarLegendShowAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:contentDescription="@string/calendar_legend_show_all_accessibility"
                android:maxLines="2"
                android:maxWidth="360dp"
                android:minHeight="48dp"
                android:minWidth="200dp"
                android:paddingHorizontal="24dp"
                android:text="@string/calendar_legend_show_all"
                android:textAllCaps="false"
                android:textColor="@color/calendar_primary_action_content"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/calendar_primary_action_background"
                app:cornerRadius="24dp"
                app:icon="@drawable/ic_calendar_list"
                app:iconGravity="textStart"
                app:iconPadding="10dp"
                app:iconTint="@color/calendar_primary_action_content"
                app:rippleColor="@color/calendar_action_ripple_light" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
