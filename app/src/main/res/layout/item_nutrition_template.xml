<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_margin="4dp" app:cardBackgroundColor="@color/nutrition_card_background" app:cardCornerRadius="18dp"
    app:strokeColor="@color/nutrition_card_stroke" app:strokeWidth="1dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp">
        <TextView android:id="@+id/tvNutritionTemplateName" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/reminder_text_primary" android:textSize="17sp" android:textStyle="bold" />
        <TextView android:id="@+id/tvNutritionTemplateDescription" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="6dp" android:textColor="@color/reminder_text_secondary" />
        <TextView android:id="@+id/tvNutritionTemplateDetail" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:textColor="@color/reminder_text_secondary" android:textSize="13sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionTemplatePreview"
            style="?attr/materialButtonOutlinedStyle" android:layout_width="match_parent" android:layout_height="48dp"
            android:layout_marginTop="8dp" android:text="@string/nutrition_template_preview_title" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

