<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/routine_card_background"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/routine_card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="64dp"
        android:orientation="horizontal"
        android:padding="6dp">

        <ImageView
            android:id="@+id/imageRoutineTaskDrag"
            android:layout_width="40dp"
            android:layout_height="48dp"
            android:contentDescription="@string/routine_task_drag_generic"
            android:padding="8dp"
            android:src="@drawable/ic_routine_drag" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvRoutineEditorTaskTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/reminder_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRoutineEditorTaskMetadata"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="@color/reminder_text_secondary"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnEditRoutineTask"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/routine_task_edit_generic"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="@color/routine_primary" />

        <ImageButton
            android:id="@+id/btnDeleteRoutineTask"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/routine_task_delete_generic"
            android:padding="12dp"
            android:src="@drawable/ic_reminder_delete"
            app:tint="@color/reminder_delete_red" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
