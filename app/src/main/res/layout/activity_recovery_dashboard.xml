<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/recovery_screen_background"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/recovery_toolbar_background"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp">
        <ImageButton android:id="@+id/btnBackRecoveryDashboard" android:layout_width="48dp" android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/recovery_back"
            android:padding="12dp" android:src="@drawable/ic_calendar_back" app:tint="@color/recovery_toolbar_text" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/recovery_module_title"
                android:textColor="@color/recovery_toolbar_text" android:textSize="21sp" android:textStyle="bold" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/recovery_module_subtitle"
                android:textColor="#DCE5EC" android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:fillViewport="true">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/recovery_warning_background"
                android:padding="12dp" android:text="@string/recovery_disclaimer" android:textColor="@color/recovery_warning_text" android:textSize="13sp" />
            <com.luistureo.voicereminderapp.presentation.assistant.AssistantDialogueBubbleView
                android:id="@+id/recoveryAssistantBubble"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:contentDescription="@string/assistant_dialogue_content_description" />

            <TextView android:id="@+id/tvRecoveryNoGoals" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center" android:padding="28dp" android:text="@string/recovery_dashboard_no_goals" android:textSize="15sp" android:visibility="gone" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnRecoveryNewGoal" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="12dp" android:minHeight="48dp" android:text="@string/recovery_dashboard_new_goal" />

            <LinearLayout android:id="@+id/containerRecoveryDashboardContent" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp"
                    android:text="@string/recovery_dashboard_active_goal" android:textSize="14sp" android:textStyle="bold" />
                <Spinner android:id="@+id/spinnerRecoveryGoals" android:layout_width="match_parent" android:layout_height="52dp"
                    android:contentDescription="@string/recovery_dashboard_select_goal" />
                <TextView android:id="@+id/tvRecoveryDaysSince" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="@color/recovery_muted" android:textSize="14sp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal">
                    <TextView android:id="@+id/tvRecoveryCurrentStreak" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:background="@color/recovery_primary_soft" android:gravity="center" android:minHeight="72dp" android:padding="10dp" />
                    <TextView android:id="@+id/tvRecoveryBestStreak" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp"
                        android:layout_weight="1" android:background="@color/recovery_primary_soft" android:gravity="center" android:minHeight="72dp" android:padding="10dp" />
                </LinearLayout>
                <TextView android:id="@+id/tvRecoveryDashboardSummary" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="10dp" android:background="@color/recovery_card_background" android:padding="14dp" android:textSize="14sp" />
                <TextView android:id="@+id/tvRecoveryToday" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" android:text="@string/recovery_dashboard_no_checkin" android:textSize="14sp" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnRecoveryCheckIn" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" android:minHeight="48dp" android:text="@string/recovery_dashboard_checkin" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnRecoverySupportNow" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="8dp" android:minHeight="48dp" android:text="@string/recovery_dashboard_support_now" app:backgroundTint="@color/recovery_support_text" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal">
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnRecoveryTools" style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:minHeight="48dp" android:text="@string/recovery_dashboard_tools" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnRecoveryContacts" style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" android:minHeight="48dp" android:text="@string/recovery_dashboard_contacts" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal">
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnRecoveryStatistics" style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:minHeight="48dp" android:text="@string/recovery_dashboard_statistics" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnRecoverySettings" style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" android:minHeight="48dp" android:text="@string/recovery_dashboard_settings" />
                </LinearLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp"
                    android:text="@string/recovery_dashboard_recent" android:textSize="17sp" android:textStyle="bold" />
                <TextView android:id="@+id/tvRecoveryNoRecent" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:paddingVertical="14dp" android:text="@string/recovery_dashboard_no_recent" android:textColor="@color/recovery_muted" />
                <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerRecoveryRecent" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:contentDescription="@string/recovery_dashboard_recent" android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
