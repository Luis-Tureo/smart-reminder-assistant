<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/recovery_screen_background" android:orientation="vertical">
    <LinearLayout android:layout_width="match_parent" android:layout_height="72dp" android:background="@color/recovery_toolbar_background" android:gravity="center_vertical" android:paddingHorizontal="8dp">
        <ImageButton android:id="@+id/btnBackRecoveryGoal" android:layout_width="48dp" android:layout_height="48dp" android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/recovery_back" android:padding="12dp" android:src="@drawable/ic_calendar_back" app:tint="@color/recovery_toolbar_text" />
        <TextView android:id="@+id/tvRecoveryGoalEditorTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="@string/recovery_goal_editor_new" android:textColor="@color/recovery_toolbar_text" android:textSize="21sp" android:textStyle="bold" />
    </LinearLayout>
    <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/recovery_warning_background" android:padding="12dp"
                android:text="@string/recovery_disclaimer" android:textColor="@color/recovery_warning_text" android:textSize="13sp" />
            <com.google.android.material.textfield.TextInputLayout android:id="@+id/layoutRecoveryGoalTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:hint="@string/recovery_goal_private_title">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputRecoveryGoalTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:maxLength="80" android:minHeight="48dp" />
            </com.google.android.material.textfield.TextInputLayout>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="@string/recovery_goal_category" android:textStyle="bold" />
            <Spinner android:id="@+id/spinnerRecoveryGoalCategory" android:layout_width="match_parent" android:layout_height="52dp" android:contentDescription="@string/recovery_goal_category" />
            <com.google.android.material.textfield.TextInputLayout android:id="@+id/layoutRecoveryCustomCategory" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/recovery_goal_custom_category" android:visibility="gone">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputRecoveryCustomCategory" android:layout_width="match_parent" android:layout_height="wrap_content" android:maxLength="80" />
            </com.google.android.material.textfield.TextInputLayout>
            <TextView android:id="@+id/tvRecoveryProfessionalGuidance" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp"
                android:background="@color/recovery_warning_background" android:padding="12dp" android:text="@string/recovery_professional_guidance" android:textColor="@color/recovery_warning_text" android:visibility="gone" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnRecoveryAdditionalOptions" style="?attr/materialButtonOutlinedStyle" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginTop="12dp" android:minHeight="48dp" android:text="@string/recovery_additional_options" />
            <LinearLayout android:id="@+id/containerRecoveryGoalAdditional" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnRecoveryStartDate" style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:minHeight="48dp" android:text="@string/recovery_goal_start_date" />
                    <com.google.android.material.button.MaterialButton android:id="@+id/btnRecoveryTargetDate" style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" android:minHeight="48dp" android:text="@string/recovery_goal_target_date" />
                </LinearLayout>
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:hint="@string/recovery_goal_reason">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputRecoveryGoalReason" android:layout_width="match_parent" android:layout_height="wrap_content" android:maxLength="2000" android:maxLines="4" />
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:hint="@string/recovery_goal_motivations">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputRecoveryGoalMotivations" android:layout_width="match_parent" android:layout_height="wrap_content" android:maxLength="2000" android:maxLines="4" />
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchRecoveryReductionTracking" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/recovery_goal_tracking_reduction" />
            </LinearLayout>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnSaveRecoveryGoal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:minHeight="52dp" android:text="@string/recovery_save" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
