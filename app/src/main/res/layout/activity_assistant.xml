<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C4CBD6">

    <FrameLayout
        android:id="@+id/headerBar"
        android:layout_width="0dp"
        android:layout_height="84dp"
        android:background="@drawable/bg_assistant_header_panel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="monospace"
            android:includeFontPadding="false"
            android:text="Asistente Virtual"
            android:textColor="#F6F1E8"
            android:letterSpacing="0.05"
            android:textSize="22sp"
            android:textStyle="bold" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/assistantSceneContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/bg_assistant_scene_frame"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="436:366"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerBar">

        <FrameLayout
            android:id="@+id/assistantSceneContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="7dp"
            android:background="@drawable/bg_assistant_scene_content"
            android:clipToOutline="true"
            android:clipChildren="true"
            android:clipToPadding="true">

            <com.luistureo.voicereminderapp.presentation.assistant.AssistantView
                android:id="@+id/assistantView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="1"
                android:contentDescription="Asistente virtual pixel art"
                android:visibility="visible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAssistantStatus"
                android:layout_width="match_parent"
                android:layout_height="66dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginStart="32dp"
                android:layout_marginEnd="32dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_assistant_dialog_panel"
                android:backgroundTint="@android:color/transparent"
                android:clickable="false"
                android:focusable="false"
                android:fontFamily="monospace"
                android:gravity="center"
                android:insetBottom="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:insetTop="0dp"
                android:minHeight="0dp"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Estoy lista"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="0dp"
                app:strokeWidth="0dp" />
        </FrameLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
