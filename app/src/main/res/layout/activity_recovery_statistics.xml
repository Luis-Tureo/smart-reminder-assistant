<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/recovery_screen_background" android:orientation="vertical">
    <LinearLayout android:layout_width="match_parent" android:layout_height="72dp" android:background="@color/recovery_toolbar_background" android:gravity="center_vertical" android:paddingHorizontal="8dp">
        <ImageButton android:id="@+id/btnBackRecoveryStatistics" android:layout_width="48dp" android:layout_height="48dp" android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/recovery_back" android:padding="12dp" android:src="@drawable/ic_calendar_back" app:tint="@color/recovery_toolbar_text" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/recovery_statistics_title" android:textColor="@color/recovery_toolbar_text" android:textSize="21sp" android:textStyle="bold" />
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
            <Spinner android:id="@+id/spinnerRecoveryStatisticsRange" android:layout_width="match_parent" android:layout_height="52dp" android:contentDescription="@string/recovery_statistics_range" />
            <TextView android:id="@+id/tvRecoveryStatisticsEmpty" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:padding="24dp" android:text="@string/recovery_statistics_empty" android:textColor="@color/recovery_muted" />
            <LinearLayout android:id="@+id/containerRecoveryStatistics" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                <TextView android:id="@+id/tvRecoveryStatisticsSummary" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/recovery_card_background" android:padding="14dp" android:textSize="15sp" />
                <ProgressBar android:id="@+id/progressRecoverySuccess" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="18dp" android:layout_marginTop="14dp" android:max="100" android:progressTint="@color/recovery_support_text" />
                <TextView android:id="@+id/tvRecoverySuccessBarLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" />
                <ProgressBar android:id="@+id/progressRecoveryDifficult" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="18dp" android:layout_marginTop="10dp" android:max="100" android:progressTint="@color/recovery_warning_text" />
                <TextView android:id="@+id/tvRecoveryDifficultBarLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="@string/recovery_statistics_triggers" android:textSize="16sp" android:textStyle="bold" />
                <TextView android:id="@+id/tvRecoveryCommonTriggers" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp" android:textColor="@color/recovery_muted" />
            </LinearLayout>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:background="@color/recovery_primary_soft" android:padding="12dp" android:text="@string/recovery_statistics_private" android:textColor="@color/recovery_primary" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
