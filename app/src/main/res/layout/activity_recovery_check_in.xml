<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/recovery_screen_background" android:orientation="vertical">
    <LinearLayout android:layout_width="match_parent" android:layout_height="72dp" android:background="@color/recovery_toolbar_background" android:gravity="center_vertical" android:paddingHorizontal="8dp">
        <ImageButton android:id="@+id/btnBackRecoveryCheckIn" android:layout_width="48dp" android:layout_height="48dp" android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/recovery_back" android:padding="12dp" android:src="@drawable/ic_calendar_back" app:tint="@color/recovery_toolbar_text" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/recovery_checkin_title" android:textColor="@color/recovery_toolbar_text" android:textSize="21sp" android:textStyle="bold" />
    </LinearLayout>
    <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/recovery_checkin_prompt" android:textSize="18sp" android:textStyle="bold" />
            <RadioGroup android:id="@+id/groupRecoveryCheckIn" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp">
                <com.google.android.material.radiobutton.MaterialRadioButton android:id="@+id/radioRecoveryAchieved" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/recovery_checkin_success" />
                <com.google.android.material.radiobutton.MaterialRadioButton android:id="@+id/radioRecoveryManaged" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/recovery_checkin_managed" />
                <com.google.android.material.radiobutton.MaterialRadioButton android:id="@+id/radioRecoveryLapse" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/recovery_checkin_lapse" />
                <com.google.android.material.radiobutton.MaterialRadioButton android:id="@+id/radioRecoverySkip" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/recovery_checkin_skip" />
            </RadioGroup>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnRecoveryCheckInAdditional" style="?attr/materialButtonOutlinedStyle" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:minHeight="48dp" android:text="@string/recovery_additional_options" />
            <LinearLayout android:id="@+id/containerRecoveryCheckInAdditional" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                <com.google.android.material.textfield.TextInputLayout android:id="@+id/layoutRecoveryIntensity" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/recovery_checkin_intensity">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputRecoveryIntensity" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="number" android:maxLength="2" />
                </com.google.android.material.textfield.TextInputLayout>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/recovery_checkin_trigger" />
                <Spinner android:id="@+id/spinnerRecoveryCheckInTrigger" android:layout_width="match_parent" android:layout_height="48dp" android:contentDescription="@string/recovery_checkin_trigger" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/recovery_checkin_helpful_action" />
                <Spinner android:id="@+id/spinnerRecoveryCheckInAction" android:layout_width="match_parent" android:layout_height="48dp" android:contentDescription="@string/recovery_checkin_helpful_action" />
                <com.google.android.material.materialswitch.MaterialSwitch android:id="@+id/switchRecoveryReducedFrequency" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/recovery_checkin_reduced" android:visibility="gone" />
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:hint="@string/recovery_checkin_note">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputRecoveryCheckInNote" android:layout_width="match_parent" android:layout_height="wrap_content" android:maxLength="1000" android:maxLines="4" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
            <TextView android:id="@+id/tvRecoveryCheckInValidation" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textColor="@color/recovery_danger" android:visibility="gone" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnSaveRecoveryCheckIn" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:minHeight="52dp" android:text="@string/recovery_save" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:background="@color/recovery_warning_background" android:padding="12dp" android:text="@string/recovery_disclaimer" android:textColor="@color/recovery_warning_text" android:textSize="13sp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
