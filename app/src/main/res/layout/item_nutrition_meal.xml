<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent"
    android:layout_height="wrap_content" android:layout_margin="4dp"
    app:cardBackgroundColor="@color/nutrition_card_background" app:cardCornerRadius="18dp"
    app:strokeColor="@color/nutrition_card_stroke" app:strokeWidth="1dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="14dp">
        <TextView android:id="@+id/tvNutritionMealPeriod" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="@color/nutrition_primary"
            android:textSize="13sp" android:textStyle="bold" />
        <TextView android:id="@+id/tvNutritionMealName" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="4dp"
            android:textColor="@color/reminder_text_primary" android:textSize="17sp" android:textStyle="bold" />
        <TextView android:id="@+id/tvNutritionMealDateTime" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginTop="4dp"
            android:textColor="@color/reminder_text_secondary" android:textSize="13sp" />
        <TextView android:id="@+id/tvNutritionMealStatus" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:layout_marginTop="6dp"
            android:textColor="@color/nutrition_success" android:textStyle="bold" />
        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:scrollbars="none" android:contentDescription="@string/nutrition_meal_actions">
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionMealEdit"
                    style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="48dp"
                    android:text="@string/nutrition_edit" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionMealDuplicate"
                    style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="48dp"
                    android:text="@string/nutrition_duplicate" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionMealMove"
                    style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="48dp"
                    android:text="@string/nutrition_move" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionMealComplete"
                    style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="48dp"
                    android:text="@string/nutrition_complete" />
                <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionMealSkip"
                    style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="48dp"
                    android:text="@string/nutrition_skip" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

