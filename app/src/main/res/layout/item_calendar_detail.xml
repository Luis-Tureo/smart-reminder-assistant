<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/calendar_detail_item_background"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/calendar_card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="15dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvCalendarDetailTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/calendar_title_text"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCalendarDetailCompleted"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="@string/calendar_completed_label"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btnCalendarDetailDelete"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_delete_circle"
                android:contentDescription="@string/delete_reminder"
                android:padding="8dp"
                android:src="@drawable/ic_reminder_delete"
                android:tint="@color/reminder_delete_red" />
        </LinearLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/groupCalendarDetailMetadata"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:chipSpacingHorizontal="6dp"
            app:chipSpacingVertical="6dp"
            app:singleLine="false">

            <TextView
                android:id="@+id/tvCalendarDetailTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_calendar_detail_time"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:textColor="@color/calendar_detail_time_text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCalendarDetailType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:textSize="12sp"
                android:textStyle="bold" />
        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:id="@+id/tvCalendarDetailDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:ellipsize="end"
            android:maxLines="3"
            android:textColor="@color/calendar_body_text"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvCalendarDetailNearbySchedule"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_calendar_nearby_schedule_badge"
            android:paddingHorizontal="9dp"
            android:paddingVertical="4dp"
            android:text="@string/calendar_duplicate_nearby_badge"
            android:textColor="@color/calendar_duplicate_warning_text"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvCalendarDetailProvider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/calendar_caption_text"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvCalendarDetailExternalNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/calendar_caption_text"
            android:textSize="12sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/containerCalendarDetailActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCalendarReactivate"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/calendar_reactivate_appointment"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:visibility="gone"
                android:insetBottom="0dp"
                android:insetTop="0dp"
                app:cornerRadius="20dp"
                />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCalendarOpenMeeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingVertical="10dp"
                android:text="@string/calendar_open_meeting"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:visibility="gone"
                android:insetBottom="0dp"
                android:insetTop="0dp"
                app:backgroundTint="@color/primary_blue"
                app:cornerRadius="20dp"
                app:icon="@drawable/ic_meeting_video"
                app:iconGravity="textStart"
                app:iconPadding="7dp"
                app:iconTint="@color/white" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
