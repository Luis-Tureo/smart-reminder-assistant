<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/recovery_card_background"
    app:cardCornerRadius="16dp"
    app:strokeColor="@color/recovery_card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvRecoveryCheckInDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/reminder_text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvRecoveryCheckInStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/reminder_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
