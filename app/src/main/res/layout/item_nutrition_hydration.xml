<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical"
    android:orientation="horizontal" android:padding="8dp">
    <TextView android:id="@+id/tvNutritionHydrationAmount" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:textColor="@color/reminder_text_primary" android:textStyle="bold" />
    <TextView android:id="@+id/tvNutritionHydrationTime" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginEnd="8dp" android:textColor="@color/reminder_text_secondary" />
    <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionHydrationDelete"
        style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="48dp"
        android:text="@string/nutrition_delete" />
</LinearLayout>

