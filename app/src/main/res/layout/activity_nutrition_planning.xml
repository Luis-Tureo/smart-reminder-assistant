<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical"
    android:background="@color/nutrition_screen_background">
    <LinearLayout android:layout_width="match_parent" android:layout_height="72dp" android:orientation="horizontal"
        android:gravity="center_vertical" android:background="@color/nutrition_toolbar_background" android:paddingHorizontal="8dp">
        <ImageButton android:id="@+id/btnBackNutritionPlanning" android:layout_width="48dp" android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/nutrition_back"
            android:src="@drawable/ic_calendar_back" android:padding="12dp" app:tint="@color/nutrition_toolbar_text" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="@string/nutrition_planning_title" android:textColor="@color/nutrition_toolbar_text"
            android:textSize="22sp" android:textStyle="bold" />
    </LinearLayout>
    <Spinner android:id="@+id/spinnerNutritionPlanningMode" android:layout_width="match_parent"
        android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:layout_marginTop="12dp" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical"
        android:orientation="horizontal" android:paddingHorizontal="12dp">
        <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionPlanningPrevious"
            style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="@string/nutrition_previous" />
        <TextView android:id="@+id/tvNutritionPlanningDate" android:layout_width="0dp" android:layout_height="48dp"
            android:layout_weight="1" android:gravity="center" android:clickable="true" android:focusable="true"
            android:textColor="@color/reminder_text_primary" android:textSize="16sp" android:textStyle="bold" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionPlanningNext"
            style="?attr/materialButtonOutlinedStyle" android:layout_width="wrap_content" android:layout_height="48dp"
            android:text="@string/nutrition_next" />
    </LinearLayout>
    <TextView android:id="@+id/tvNutritionPlanningEmpty" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center" android:padding="24dp" android:text="@string/nutrition_planning_empty"
        android:textColor="@color/reminder_text_secondary" />
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerNutritionPlanning" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1" android:paddingHorizontal="12dp" android:clipToPadding="false" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"
        android:padding="12dp">
        <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionCopyDay"
            style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_height="52dp"
            android:layout_weight="1" android:layout_marginEnd="6dp" android:text="@string/nutrition_copy_day" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionPlanningAdd"
            android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
            android:layout_marginStart="6dp" android:text="@string/nutrition_quick_add" />
    </LinearLayout>
</LinearLayout>

