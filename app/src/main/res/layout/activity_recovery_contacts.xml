<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/recovery_screen_background" android:orientation="vertical">
    <LinearLayout android:layout_width="match_parent" android:layout_height="72dp" android:background="@color/recovery_toolbar_background" android:gravity="center_vertical" android:paddingHorizontal="8dp">
        <ImageButton android:id="@+id/btnBackRecoveryContacts" android:layout_width="48dp" android:layout_height="48dp" android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/recovery_back" android:padding="12dp" android:src="@drawable/ic_calendar_back" app:tint="@color/recovery_toolbar_text" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/recovery_contacts_title" android:textColor="@color/recovery_toolbar_text" android:textSize="21sp" android:textStyle="bold" />
    </LinearLayout>
    <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/btnPickRecoveryContact" style="?attr/materialButtonOutlinedStyle" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/recovery_contacts_pick" />
            <com.google.android.material.textfield.TextInputLayout android:id="@+id/layoutRecoveryContactName" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/recovery_contacts_name">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputRecoveryContactName" android:layout_width="match_parent" android:layout_height="wrap_content" android:maxLength="100" />
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/recovery_contacts_description">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputRecoveryContactDescription" android:layout_width="match_parent" android:layout_height="wrap_content" android:maxLength="150" />
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout android:id="@+id/layoutRecoveryContactPhone" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/recovery_contacts_phone">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputRecoveryContactPhone" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="phone" android:maxLength="40" />
            </com.google.android.material.textfield.TextInputLayout>
            <Spinner android:id="@+id/spinnerRecoveryContactAction" android:layout_width="match_parent" android:layout_height="48dp" android:contentDescription="@string/recovery_contacts_preferred_action" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnSaveRecoveryContact" android:layout_width="match_parent" android:layout_height="wrap_content" android:minHeight="48dp" android:text="@string/recovery_contacts_add" />
            <TextView android:id="@+id/tvRecoveryContactsEmpty" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:padding="20dp" android:text="@string/recovery_contacts_empty" android:textColor="@color/recovery_muted" />
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerRecoveryContacts" android:layout_width="match_parent" android:layout_height="wrap_content" android:contentDescription="@string/recovery_contacts_title" android:nestedScrollingEnabled="false" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@color/recovery_warning_background" android:padding="12dp" android:text="@string/recovery_contacts_local_notice" android:textColor="@color/recovery_warning_text" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
