<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/nutrition_screen_background">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingBottom="24dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="72dp" android:orientation="horizontal"
            android:gravity="center_vertical" android:background="@color/nutrition_toolbar_background" android:paddingHorizontal="8dp">
            <ImageButton android:id="@+id/btnBackNutritionPreferences" android:layout_width="48dp" android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/nutrition_back"
                android:src="@drawable/ic_calendar_back" android:padding="12dp" app:tint="@color/nutrition_toolbar_text" />
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="@string/nutrition_preferences_title" android:textColor="@color/nutrition_toolbar_text"
                android:textSize="22sp" android:textStyle="bold" />
        </LinearLayout>
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp"
            android:text="@string/nutrition_preferences_intro" android:textColor="@color/reminder_text_secondary" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="16dp"
            android:text="@string/nutrition_dietary_style" android:textStyle="bold" />
        <Spinner android:id="@+id/spinnerNutritionDietaryStyle" android:layout_width="match_parent" android:layout_height="52dp"
            android:layout_marginHorizontal="16dp" />
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputNutritionDislikes"
            android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginHorizontal="16dp"
            android:hint="@string/nutrition_dislikes" />
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputNutritionExclusions"
            android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginHorizontal="16dp"
            android:hint="@string/nutrition_exclusions" />
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputNutritionAllergies"
            android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginHorizontal="16dp"
            android:hint="@string/nutrition_allergies" />
        <TextView android:id="@+id/tvNutritionAllergyWarning" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp" android:background="@color/nutrition_warning_background" android:padding="12dp"
            android:text="@string/nutrition_allergy_warning" android:textColor="@color/nutrition_warning_text" android:visibility="gone" />
        <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputNutritionPreferredFoods"
            android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginHorizontal="16dp"
            android:hint="@string/nutrition_preferred_foods" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp" android:text="@string/nutrition_goals_title" android:textStyle="bold" />
        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/checkNutritionGoalMealTimes"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:text="@string/nutrition_goal_meal_times" />
        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/checkNutritionGoalMealReminders"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:text="@string/nutrition_goal_meal_reminders" />
        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/checkNutritionGoalHydration"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:text="@string/nutrition_goal_hydration" />
        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/checkNutritionGoalPreparation"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:text="@string/nutrition_goal_preparation" />
        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/checkNutritionGoalVariety"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:text="@string/nutrition_goal_variety" />
        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/checkNutritionGoalReduceForgetfulness"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:text="@string/nutrition_goal_reduce_forgetfulness" />
        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/checkNutritionGoalShopping"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:text="@string/nutrition_goal_shopping" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp" android:text="@string/nutrition_enabled_periods" android:textStyle="bold" />
        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/checkNutritionBreakfast"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:text="@string/nutrition_period_breakfast" />
        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/checkNutritionMorningSnack"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:text="@string/nutrition_period_morning_snack" />
        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/checkNutritionLunch"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:text="@string/nutrition_period_lunch" />
        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/checkNutritionAfternoonSnack"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:text="@string/nutrition_period_afternoon_snack" />
        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/checkNutritionDinner"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:text="@string/nutrition_period_dinner" />
        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/checkNutritionRemindersEnabled"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:text="@string/nutrition_reminders_enabled" />
        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/checkNutritionVoiceEnabled"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:text="@string/nutrition_voice_enabled" />
        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/checkNutritionBubbleEnabled"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:text="@string/nutrition_bubble_enabled" />
        <com.google.android.material.checkbox.MaterialCheckBox android:id="@+id/checkNutritionPrivacyEnabled"
            android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginHorizontal="16dp" android:text="@string/nutrition_privacy_enabled" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp" android:text="@string/nutrition_chart_preference" android:textStyle="bold" />
        <Spinner android:id="@+id/spinnerNutritionChartType" android:layout_width="match_parent" android:layout_height="52dp"
            android:layout_marginHorizontal="16dp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnSaveNutritionPreferences"
            android:layout_width="match_parent" android:layout_height="52dp" android:layout_margin="16dp"
            android:text="@string/nutrition_save_preferences" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
