<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C4CBD6">

    <FrameLayout
        android:id="@+id/headerBar"
        android:layout_width="0dp"
        android:layout_height="84dp"
        android:background="@drawable/bg_assistant_header_panel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="monospace"
            android:includeFontPadding="false"
            android:text="@string/assistant_screen_title"
            android:textColor="#F6F1E8"
            android:letterSpacing="0.05"
            android:textSize="22sp"
            android:textStyle="bold" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/assistantSceneContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="18dp"
        android:background="@drawable/bg_assistant_scene_frame"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="10dp"
        app:layout_constraintDimensionRatio="432:338"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerBar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/assistantSceneContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="7dp"
            android:background="@drawable/bg_assistant_scene_content"
            android:clipChildren="true"
            android:clipToOutline="true"
            android:clipToPadding="true">

            <com.luistureo.voicereminderapp.presentation.assistant.AssistantView
                android:id="@+id/assistantView"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:alpha="1"
                android:contentDescription="@string/assistant_character_content_description"
                android:visibility="visible"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.luistureo.voicereminderapp.presentation.assistant.AssistantDialogueBubbleView
                android:id="@+id/assistantDialogueBubble"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="14dp"
                android:layout_marginBottom="8dp"
                android:contentDescription="@string/assistant_dialogue_content_description"
                android:visibility="invisible"
                app:layout_constraintBottom_toTopOf="@id/tvAssistantTapHint"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="1" />

            <TextView
                android:id="@+id/tvAssistantTapHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_assistant_tap_hint"
                android:fontFamily="monospace"
                android:includeFontPadding="false"
                android:letterSpacing="0.06"
                android:paddingStart="14dp"
                android:paddingTop="10dp"
                android:paddingEnd="14dp"
                android:paddingBottom="10dp"
                android:text="@string/assistant_tap_hint"
                android:textColor="#1D2433"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOpenCalendar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="@dimen/main_calendar_button_top_spacing"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="@dimen/main_calendar_button_bottom_spacing"
        android:paddingVertical="14dp"
        android:text="@string/open_calendar_button"
        android:textAllCaps="false"
        android:textColor="@color/calendar_toolbar_text"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/calendar_toolbar_background"
        app:cornerRadius="22dp"
        app:icon="@drawable/ic_reminder_calendar"
        app:iconPadding="10dp"
        app:iconTint="@color/calendar_toolbar_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/assistantSceneContainer"
        app:rippleColor="@color/ripple_soft" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerReminders"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnOpenCalendar" />

</androidx.constraintlayout.widget.ConstraintLayout>
