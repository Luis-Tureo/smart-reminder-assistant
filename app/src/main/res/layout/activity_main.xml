<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C4CBD6"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <LinearLayout
            android:id="@+id/headerBar"
            android:layout_width="match_parent"
            android:layout_height="112dp"
            android:background="@drawable/bg_assistant_header_panel"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="18dp">

            <TextView
                android:id="@+id/tvHomeTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/home_screen_title"
                android:textColor="#F6F1E8"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHomeSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:maxLines="2"
                android:text="@string/home_screen_subtitle"
                android:textColor="#DDE5EE"
                android:textSize="14sp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCalendar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/reminder_card_background"
            app:cardCornerRadius="28dp"
            app:cardElevation="5dp"
            app:rippleColor="@color/ripple_soft"
            app:strokeColor="@color/reminder_card_stroke"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="96dp"
                android:padding="18dp">

                <FrameLayout
                    android:id="@+id/calendarIconContainer"
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:background="@drawable/bg_reminder_icon_blue"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_reminder_calendar"
                        app:tint="@color/reminder_icon_blue_fg" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvCalendarTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:text="@string/home_calendar_title"
                    android:textColor="@color/reminder_text_primary"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/calendarIconContainer"
                    app:layout_constraintTop_toTopOf="@id/calendarIconContainer" />

                <TextView
                    android:id="@+id/tvCalendarSubtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/home_calendar_subtitle"
                    android:textColor="@color/reminder_text_secondary"
                    android:textSize="15sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/calendarIconContainer"
                    app:layout_constraintTop_toBottomOf="@id/tvCalendarTitle" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAssistantReminder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/reminder_card_background"
            app:cardCornerRadius="28dp"
            app:cardElevation="5dp"
            app:rippleColor="@color/ripple_soft"
            app:strokeColor="@color/reminder_card_stroke"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="96dp"
                android:padding="18dp">

                <FrameLayout
                    android:id="@+id/assistantIconContainer"
                    android:layout_width="62dp"
                    android:layout_height="62dp"
                    android:background="@drawable/bg_reminder_icon_blue"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@android:drawable/ic_btn_speak_now"
                        app:tint="@color/reminder_icon_blue_fg" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvAssistantReminderTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:text="@string/home_virtual_assistant_title"
                    android:textColor="@color/reminder_text_primary"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/assistantIconContainer"
                    app:layout_constraintTop_toTopOf="@id/assistantIconContainer" />

                <TextView
                    android:id="@+id/tvAssistantReminderSubtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/home_virtual_assistant_subtitle"
                    android:textColor="@color/reminder_text_secondary"
                    android:textSize="15sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/assistantIconContainer"
                    app:layout_constraintTop_toBottomOf="@id/tvAssistantReminderTitle" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
