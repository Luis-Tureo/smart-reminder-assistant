<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/routine_toolbar_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btnBackRoutineDashboard"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/routine_back"
            android:padding="12dp"
            android:src="@drawable/ic_calendar_back"
            app:tint="@color/routine_toolbar_text" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/routine_module_title"
            android:textColor="@color/routine_toolbar_text"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvRoutineDashboardSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:text="@string/routine_dashboard_subtitle"
        android:textColor="@color/reminder_text_secondary"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tvRoutineDashboardEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp"
        android:text="@string/routine_empty_dashboard"
        android:textColor="@color/reminder_text_secondary"
        android:textSize="15sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerRoutineDashboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:contentDescription="@string/routine_module_title"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRoutineTemplates"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:minHeight="48dp"
            android:text="@string/routine_templates"
            android:textAllCaps="false"
            app:cornerRadius="22dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateRoutine"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:minHeight="48dp"
            android:text="@string/routine_create"
            android:textAllCaps="false"
            app:cornerRadius="22dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingBottom="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRoutineProgress"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:layout_marginEnd="6dp" android:text="@string/routine_progress_title" android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRoutineSuggestions"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:layout_marginStart="6dp" android:text="@string/routine_suggestions_title" android:textAllCaps="false" />
    </LinearLayout>
</LinearLayout>
