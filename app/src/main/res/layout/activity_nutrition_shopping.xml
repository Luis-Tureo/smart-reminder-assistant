<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical"
    android:background="@color/nutrition_screen_background">
    <LinearLayout android:layout_width="match_parent" android:layout_height="72dp" android:orientation="horizontal"
        android:gravity="center_vertical" android:background="@color/nutrition_toolbar_background" android:paddingHorizontal="8dp">
        <ImageButton android:id="@+id/btnBackNutritionShopping" android:layout_width="48dp" android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless" android:contentDescription="@string/nutrition_back"
            android:src="@drawable/ic_calendar_back" android:padding="12dp" app:tint="@color/nutrition_toolbar_text" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="@string/nutrition_shopping_title" android:textColor="@color/nutrition_toolbar_text" android:textSize="22sp" android:textStyle="bold" />
    </LinearLayout>
    <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputNutritionShoppingName"
        android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp" android:hint="@string/nutrition_shopping_name" />
    <com.google.android.material.textfield.TextInputEditText android:id="@+id/inputNutritionShoppingQuantity"
        android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginHorizontal="16dp"
        android:hint="@string/nutrition_shopping_quantity" />
    <Spinner android:id="@+id/spinnerNutritionShoppingCategory" android:layout_width="match_parent" android:layout_height="48dp"
        android:layout_marginHorizontal="16dp" android:contentDescription="@string/nutrition_shopping_category" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingHorizontal="12dp">
        <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionShoppingAdd"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp"
            android:text="@string/nutrition_shopping_add" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionShoppingFromPlan"
            style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:layout_margin="4dp" android:text="@string/nutrition_shopping_from_plan" />
    </LinearLayout>
    <TextView android:id="@+id/tvNutritionShoppingEmpty" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center" android:padding="20dp" android:text="@string/nutrition_shopping_empty"
        android:textColor="@color/reminder_text_secondary" />
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerNutritionShopping" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1" android:paddingHorizontal="12dp" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="12dp">
        <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionShoppingRemoveCompleted"
            style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:layout_marginEnd="4dp" android:text="@string/nutrition_remove_completed" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btnNutritionShoppingClear"
            style="?attr/materialButtonOutlinedStyle" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:layout_marginStart="4dp" android:text="@string/nutrition_clear_list" />
    </LinearLayout>
</LinearLayout>

