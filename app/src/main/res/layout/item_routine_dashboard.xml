<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    android:clickable="true"
    android:focusable="true"
    android:minHeight="112dp"
    app:cardBackgroundColor="@color/routine_card_background"
    app:cardCornerRadius="@dimen/routine_card_radius"
    app:cardElevation="2dp"
    app:rippleColor="@color/ripple_soft"
    app:strokeColor="@color/routine_card_stroke"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <ImageView
            android:id="@+id/imageRoutinePeriod"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_routine_icon"
            android:contentDescription="@null"
            android:padding="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvRoutineDashboardName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/reminder_text_primary"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/tvRoutineDashboardPercentage"
            app:layout_constraintStart_toEndOf="@id/imageRoutinePeriod"
            app:layout_constraintTop_toTopOf="@id/imageRoutinePeriod" />

        <TextView
            android:id="@+id/tvRoutineDashboardPercentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="44dp"
            android:gravity="end"
            android:textColor="@color/routine_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvRoutineDashboardName" />

        <TextView
            android:id="@+id/tvRoutineDashboardStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:textColor="@color/reminder_text_secondary"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/imageRoutinePeriod"
            app:layout_constraintTop_toBottomOf="@id/tvRoutineDashboardName" />

        <TextView
            android:id="@+id/tvRoutineDashboardProgress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/reminder_text_secondary"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imageRoutinePeriod" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressRoutineDashboard"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_marginTop="8dp"
            android:max="100"
            app:indicatorColor="@color/routine_primary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvRoutineDashboardProgress"
            app:trackColor="@color/routine_primary_soft"
            app:trackCornerRadius="3dp" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
