<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#263556" />
            <corners android:radius="28dp" />
        </shape>
    </item>

    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#6779A1" />
            <corners android:radius="26dp" />
        </shape>
    </item>

    <item
        android:left="5dp"
        android:top="5dp"
        android:right="5dp"
        android:bottom="5dp">
        <shape android:shape="rectangle">
            <solid android:color="#D8D1C7" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <item
        android:left="7dp"
        android:top="7dp"
        android:right="7dp"
        android:bottom="7dp">
        <shape android:shape="rectangle">
            <solid android:color="#F6F0E5" />
            <corners android:radius="22dp" />
            <stroke
                android:width="1dp"
                android:color="#EFE6D8" />
        </shape>
    </item>
</layer-list>
