# Copiar como keystore.properties y completar solo en el equipo de release.
# También se pueden usar RELEASE_STORE_FILE, RELEASE_STORE_PASSWORD,
# RELEASE_KEY_ALIAS y RELEASE_KEY_PASSWORD como variables de entorno.
storeFile=<ruta-al-keystore>
storePassword=<contrasena-del-keystore>
keyAlias=<alias-de-la-clave>
keyPassword=<contrasena-de-la-clave>
